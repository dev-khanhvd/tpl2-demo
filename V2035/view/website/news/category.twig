<modal-dialog class="thb-localization-forms-modal" data-moved="true" id="LocalizationModal--locale">
 <div aria-modal="true" class="thb-localization-forms-modal__content" role="dialog" tabindex="-1">
  <div class="thb-localization-forms-modal__content-header">
   <span class="h5 body-font">
    Select your language
   </span>
   <button aria-label="Close" class="thb-localization-forms-modal__toggle" id="ModalClose-LocalizationModal--locale" type="button">
    <svg fill="none" height="14" viewbox="0 0 14 14" width="14" xmlns="http://www.w3.org/2000/svg">
     <path d="M13 1L1 13M13 13L1 1" stroke="var(--color-body)" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5">
     </path>
    </svg>
   </button>
  </div>
  <div class="thb-localization-forms-modal__content-info">
   <p>
    Your currently selected language is English.
   </p>
   <form accept-charset="UTF-8" action="/localization" class="shopify-localization-form" enctype="multipart/form-data" id="LocalizationModal--locale-form" method="post">
    <input name="form_type" type="hidden" value="localization"/>
    <input name="utf8" type="hidden" value="✓"/>
    <input name="_method" type="hidden" value="put"/>
    <input name="return_to" type="hidden" value="/blogs/our-commitment"/>
    <div class="select">
     <select class="thb-language-code full" name="locale_code">
      <option selected="selected" value="en">
       English
      </option>
      <option value="ja">
       日本語
      </option>
      <option value="fr">
       français
      </option>
      <option value="th">
       ภาษาไทย
      </option>
      <option value="de">
       Deutsch
      </option>
      <option value="ar">
       العربية
      </option>
     </select>
     <div class="select-arrow">
      <svg fill="none" height="6" viewbox="0 0 8 6" width="8" xmlns="http://www.w3.org/2000/svg">
       <path d="M6.75 1.5L3.75 4.5L0.75 1.5" stroke="var(--color-body)" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.1">
       </path>
      </svg>
     </div>
    </div>
    <button class="button">
     <span data-content="Update language">
     </span>
    </button>
   </form>
  </div>
 </div>
</modal-dialog>
